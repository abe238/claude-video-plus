#!/bin/sh
real=~/.local/pipx/venvs/agent-reach/bin/yt-dlp
root=~/Documents/Github/claude-video-plus/docs/evidence/v1/P01-control/live-local-control-snapshots/caption-snapshots
"$real" "$@"
status=$?
template=
want_output=0
for arg in "$@"; do
  if [ "$want_output" = 1 ]; then template=$arg; want_output=0; continue; fi
  case "$arg" in
    -o|--output) want_output=1 ;;
    --output=*) template=${arg#--output=} ;;
  esac
done
if [ -n "$template" ]; then
  source_dir=$(dirname "$template")
  index=1
  while ! mkdir "$root/call-$index" 2>/dev/null; do index=$((index + 1)); done
  for file in "$source_dir"/video*.vtt; do
    [ -f "$file" ] && cp "$file" "$root/call-$index/"
  done
fi
exit "$status"
